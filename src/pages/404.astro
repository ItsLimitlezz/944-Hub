---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/url';
---

<BaseLayout title="Page not found">
  <div class="mx-auto max-w-lg py-20 text-center">
    <p class="font-display text-7xl font-extrabold text-guards">404</p>
    <h1 class="mt-4 font-display text-2xl font-bold text-ink">This page is up on jack stands</h1>
    <p class="mt-2 text-ink-soft">We couldn't find that page. It may have been moved or never existed.</p>
    <div class="mt-8 flex justify-center gap-3">
      <a href={withBase('/')} class="rounded-md bg-guards px-5 py-3 text-sm font-bold text-white hover:bg-guards-dark">Back home</a>
      <a href={withBase('/search')} class="rounded-md border border-line px-5 py-3 text-sm font-semibold text-ink hover:border-guards/40">Search</a>
    </div>
  </div>
</BaseLayout>
