---
import type { GetStaticPaths } from 'astro';
import { withBase } from '../../../lib/url';
import { render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AttributionBadge from '../../../components/AttributionBadge.astro';
import DifficultyBadge from '../../../components/DifficultyBadge.astro';
import { getCategory } from '../../../lib/categories';
import { getArticles, getArticlesByCategory } from '../../../lib/content';
import { AUTHORS } from '../../../lib/site';
import { SITE } from '../../../lib/site';

export const getStaticPaths = (async () => {
  const articles = await getArticles();
  return articles.map((a) => ({
    params: { category: a.data.category, slug: a.id.split('/').pop()! },
    props: { article: a },
  }));
}) satisfies GetStaticPaths;

const { article } = Astro.props;
const { Content, headings } = await render(article);
const cat = getCategory(article.data.category)!;
const author = AUTHORS[article.data.author];

// Prev / next within the same category for sequential reading.
const siblings = await getArticlesByCategory(cat.id);
const idx = siblings.findIndex((a) => a.id === article.id);
const prev = idx > 0 ? siblings[idx - 1] : undefined;
const next = idx < siblings.length - 1 ? siblings[idx + 1] : undefined;
const slugOf = (id: string) => id.split('/').pop();

const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const editUrl = `${SITE.github}/edit/main/src/content/articles/${article.id}.md`;
---

<BaseLayout title={article.data.title} description={article.data.description ?? cat.blurb}>
  <div class="lg:grid lg:grid-cols-[1fr_15rem] lg:gap-10">
    <article class="min-w-0">
      <nav class="text-sm text-ink-soft/70">
        <a href={withBase('/')} class="hover:text-guards">Home</a> <span class="px-1">/</span>
        <a href={withBase('/manual')} class="hover:text-guards">Manual</a> <span class="px-1">/</span>
        <a href={withBase(`/manual/${cat.id}`)} class="hover:text-guards">{cat.name}</a>
      </nav>

      <header class="mt-4 border-b border-line pb-6">
        {article.data.subsystem && (
          <p class="text-sm font-bold uppercase tracking-wider text-guards">{article.data.subsystem}</p>
        )}
        <h1 class="mt-1 font-display text-3xl font-extrabold leading-tight text-ink sm:text-4xl">{article.data.title}</h1>
        <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-ink-soft">
          <span class="inline-flex items-center gap-2">
            <AttributionBadge author={article.data.author} size="md" />
            <span>
              {article.data.author === 'CG' ? 'Sourced from' : 'By'}
              {author.url ? (
                <a href={article.data.sourceUrl ?? author.url} class="font-semibold text-ink hover:text-guards">{article.data.authorName ?? author.full}</a>
              ) : (
                <span class="font-semibold text-ink">{article.data.authorName ?? author.full}</span>
              )}
            </span>
          </span>
          <DifficultyBadge level={article.data.difficulty} size="md" />
          {article.data.code && <span class="font-mono text-xs uppercase tracking-wide text-ink-soft/50">{article.data.code}</span>}
        </div>
      </header>

      {article.data.author === 'CG' && article.data.sourceUrl && (
        <div class="mt-6 flex items-start gap-3 rounded-lg border border-brick/20 bg-brick/5 p-4 text-sm">
          <span class="rounded-sm bg-brick px-1.5 py-px font-mono text-[0.62rem] font-bold text-white">CG</span>
          <p class="text-ink-soft">
            This guide is preserved from <strong class="text-ink">Clark's Garage</strong>, a foundational 944 resource.
            <a href={article.data.sourceUrl} target="_blank" rel="noopener" class="font-semibold text-guards-dark hover:underline">View the original →</a>
          </p>
        </div>
      )}

      <div class="prose-944 prose prose-neutral mt-8">
        <Content />
      </div>

      <!-- Prev / next -->
      <nav class="mt-12 grid gap-3 border-t border-line pt-6 sm:grid-cols-2">
        {prev ? (
          <a href={withBase(`/manual/${cat.id}/${slugOf(prev.id)}`)} class="group rounded-lg border border-line p-4 hover:border-guards/40">
            <span class="text-xs font-semibold uppercase tracking-wider text-ink-soft/50">← Previous</span>
            <span class="mt-1 block font-semibold text-ink group-hover:text-guards-dark">{prev.data.title}</span>
          </a>
        ) : <span></span>}
        {next && (
          <a href={withBase(`/manual/${cat.id}/${slugOf(next.id)}`)} class="group rounded-lg border border-line p-4 text-right hover:border-guards/40">
            <span class="text-xs font-semibold uppercase tracking-wider text-ink-soft/50">Next →</span>
            <span class="mt-1 block font-semibold text-ink group-hover:text-guards-dark">{next.data.title}</span>
          </a>
        )}
      </nav>
    </article>

    <!-- Sidebar -->
    <aside class="mt-10 hidden lg:block">
      <div class="sticky top-24 space-y-6">
        {toc.length > 0 && (
          <nav>
            <p class="text-xs font-bold uppercase tracking-wider text-ink-soft/50">On this page</p>
            <ul class="mt-3 space-y-2 border-l border-line text-sm">
              {toc.map((h) => (
                <li>
                  <a href={`#${h.slug}`} class:list={['block border-l-2 border-transparent py-0.5 text-ink-soft hover:border-guards hover:text-guards', h.depth === 3 ? 'pl-6' : 'pl-3']}>{h.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        )}
        <div class="rounded-lg border border-line bg-surface p-4 text-sm">
          <p class="font-semibold text-ink">Spotted an error?</p>
          <p class="mt-1 text-ink-soft/80">Help keep this accurate.</p>
          <a href={editUrl} target="_blank" rel="noopener" class="mt-3 inline-flex items-center gap-1 font-semibold text-guards hover:underline">Edit on GitHub →</a>
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>
