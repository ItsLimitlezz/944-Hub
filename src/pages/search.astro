---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CATEGORIES } from '../lib/categories';
import { withBase } from '../lib/url';
const searchEndpoint = withBase('/search-index.json');
---

<BaseLayout title="Search" description="Search the 944 Hub repair manual.">
  <h1 class="font-display text-4xl font-extrabold text-ink">Search</h1>
  <p class="mt-2 text-ink-soft">Find any repair article by title, system, or Clark's Garage code.</p>

  <div class="mt-6 flex items-center gap-2 rounded-xl border border-line bg-surface px-4 py-3 shadow-sm focus-within:border-guards/50">
    <svg viewBox="0 0 24 24" class="h-5 w-5 text-ink-soft/50" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" /></svg>
    <input id="q" type="search" autofocus placeholder="e.g. timing belt, brake bleeding, DME, oil seal…" class="w-full bg-transparent text-ink outline-none placeholder:text-ink-soft/40" />
  </div>

  <div id="filters" class="mt-4 flex flex-wrap gap-2">
    <button data-cat="all" class="cat-chip rounded-full border border-guards bg-guards px-3 py-1 text-xs font-semibold text-white">All</button>
    {CATEGORIES.map((c) => (
      <button data-cat={c.id} class="cat-chip rounded-full border border-line bg-surface px-3 py-1 text-xs font-semibold text-ink-soft hover:border-guards/40">{c.short}</button>
    ))}
  </div>

  <p id="count" class="mt-6 text-sm text-ink-soft/70"></p>
  <ul id="results" class="mt-2 divide-y divide-line/70 rounded-xl border border-line bg-surface" data-endpoint={searchEndpoint}></ul>
  <p id="empty" class="mt-10 hidden text-center text-ink-soft">No matching articles. Try another term.</p>
</BaseLayout>

<script>
  type Item = { title: string; category: string; categoryName: string; subsystem: string; author: string; difficulty: string; code: string; url: string };

  const tone: Record<string, string> = { CG: 'bg-brick', FFP: 'bg-guards', community: 'bg-ink-soft' };
  const label: Record<string, string> = { CG: 'CG', FFP: 'FFP', community: 'CC' };
  const diff: Record<string, { t: string; l: string }> = {
    beginner: { t: 'text-emerald-400', l: 'Beginner' },
    intermediate: { t: 'text-amber-400', l: 'Intermediate' },
    advanced: { t: 'text-red-400', l: 'Advanced' },
  };

  let data: Item[] = [];
  let cat = 'all';
  const q = document.getElementById('q') as HTMLInputElement;
  const results = document.getElementById('results')!;
  const count = document.getElementById('count')!;
  const empty = document.getElementById('empty')!;

  function render() {
    const term = q.value.trim().toLowerCase();
    let items = data;
    if (cat !== 'all') items = items.filter((i) => i.category === cat);
    if (term) {
      items = items.filter((i) =>
        (i.title + ' ' + i.subsystem + ' ' + i.code + ' ' + i.categoryName).toLowerCase().includes(term),
      );
    }
    items = items.slice(0, 200);
    results.innerHTML = items
      .map(
        (i) => `<li><a href="${i.url}" class="flex items-center gap-3 px-4 py-3 hover:bg-paper">
          <span class="rounded-sm ${tone[i.author] ?? 'bg-ink-soft'} px-1.5 py-px font-mono text-[0.6rem] font-bold text-white">${label[i.author] ?? '?'}</span>
          <span class="min-w-0 flex-1"><span class="font-medium text-ink">${i.title}</span>
          <span class="ml-2 text-xs text-ink-soft/60">${i.categoryName}${i.subsystem ? ' · ' + i.subsystem : ''}</span></span>
          <span class="hidden shrink-0 font-mono text-[0.6rem] font-bold uppercase tracking-wider sm:inline ${diff[i.difficulty]?.t ?? 'text-ink-soft'}">${diff[i.difficulty]?.l ?? ''}</span>
        </a></li>`,
      )
      .join('');
    count.textContent = `${items.length} ${items.length === 1 ? 'result' : 'results'}`;
    empty.classList.toggle('hidden', items.length > 0);
  }

  document.querySelectorAll<HTMLButtonElement>('.cat-chip').forEach((btn) =>
    btn.addEventListener('click', () => {
      cat = btn.dataset.cat!;
      document.querySelectorAll('.cat-chip').forEach((b) => {
        b.classList.remove('bg-guards', 'text-white', 'border-guards');
        b.classList.add('bg-surface', 'text-ink-soft', 'border-line');
      });
      btn.classList.add('bg-guards', 'text-white', 'border-guards');
      btn.classList.remove('bg-surface', 'text-ink-soft', 'border-line');
      render();
    }),
  );
  q.addEventListener('input', render);

  fetch(results.dataset.endpoint ?? '/search-index.json')
    .then((r) => r.json())
    .then((d: Item[]) => {
      data = d;
      render();
    });
</script>
