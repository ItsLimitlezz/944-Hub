---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PARTS, type PartKind } from '../data/parts';
import { MODELS, getModel } from '../data/models';
import { MANUAL_CATEGORIES, getCategory } from '../lib/categories';
import { getArticles } from '../lib/content';
import { withBase } from '../lib/url';
import { SITE } from '../lib/site';

// Reverse index: part id -> [{ title, url }] of guides that use it.
const articles = await getArticles();
const usedIn = new Map<string, { title: string; url: string }[]>();
for (const a of articles) {
  for (const id of a.data.parts ?? []) {
    if (!usedIn.has(id)) usedIn.set(id, []);
    usedIn.get(id)!.push({ title: a.data.title, url: withBase(`/manual/${a.data.category}/${a.id.split('/').pop()}`) });
  }
}
for (const list of usedIn.values()) list.sort((x, y) => x.title.localeCompare(y.title));

const KINDS: { id: PartKind; name: string; blurb: string }[] = [
  { id: 'maintenance', name: 'Maintenance & Consumables', blurb: 'Service items: oil, filters, fluids, belts and other wear parts.' },
  { id: 'replacement', name: 'Replacement Parts', blurb: 'Components you fit when something fails, wears out or gets upgraded.' },
];

const fitmentLabel = (f: string) => (f === 'all' ? 'All 944s' : getModel(f)?.name ?? f);

// Factory parts catalogs hosted under /public/catalogs/.
const CATALOGS = [
  { year: '1982–1985', file: 'KAT005_E_944_85_KATALOG.pdf' },
  { year: '1985–1988', file: 'KAT008_E_944_88_KATALOG.pdf' },
  { year: '1989–1991', file: 'KAT014_E_944_91_KATALOG.pdf' },
];
---

<BaseLayout title="Parts Catalog" description="Interactive Porsche 944 parts catalog — pick your variant and system to find the right parts, where to buy them, 3D-printable options and the guides that use them.">
  <p class="text-sm font-bold uppercase tracking-wider text-guards">Reference</p>
  <h1 class="mt-1 font-display text-4xl font-extrabold uppercase tracking-tight text-ink">Parts Catalog</h1>
  <p class="mt-2 max-w-3xl text-ink-soft">
    Pick your 944 and a system to find the right parts — where to buy them, 3D-printable options where
    they exist, and the guides that use them. Some parts differ by variant (Turbo, S2, …), so set your
    car first.
  </p>
  <p class="mt-3 max-w-3xl text-xs text-ink-soft/60">{SITE.affiliate.short}</p>

  <!-- ── Visual catalog CTA ───────────────────────────── -->
  <a href={withBase('/catalog')} class="group mt-6 flex flex-col gap-4 overflow-hidden rounded-2xl border border-guards/30 bg-carbon-grid p-6 transition hover:border-guards/60 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex items-start gap-4">
      <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-guards/15 text-guards">
        <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8 12 3 3 8m18 0-9 5-9-5m18 0v8l-9 5-9-5V8M3 8v8l9 5" /></svg>
      </span>
      <div>
        <h2 class="font-display text-lg font-extrabold text-white">Browse the visual factory catalog</h2>
        <p class="mt-1 max-w-xl text-sm text-white/60">Exploded diagrams for every assembly and the exact OEM part number for each piece — search by name or number, straight from the Porsche catalog.</p>
      </div>
    </div>
    <span class="shrink-0 rounded-md bg-guards px-5 py-3 text-sm font-bold text-white group-hover:bg-guards-dark">Open catalog →</span>
  </a>

  <!-- ── Step 1: car selector ─────────────────────────── -->
  <div class="mt-6">
    <p class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.18em] text-ink-soft/50">1 · Your car</p>
    <div id="model-filter" class="mt-2 flex flex-wrap gap-2">
      <button type="button" data-model="all" aria-pressed="true" class="model-chip rounded-full border border-guards bg-guards/15 px-3 py-1.5 text-sm font-semibold text-guards transition">All 944s</button>
      {MODELS.map((m) => (
        <button type="button" data-model={m.id} aria-pressed="false" title={`${m.years} · ${m.blurb}`} class="model-chip rounded-full border border-line bg-surface px-3 py-1.5 text-sm font-semibold text-ink-soft transition hover:border-guards/40">
          {m.name}
        </button>
      ))}
    </div>
  </div>

  <!-- ── Step 2: system + search ──────────────────────── -->
  <div class="mt-5">
    <p class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.18em] text-ink-soft/50">2 · System</p>
    <div id="system-filter" class="mt-2 flex flex-wrap gap-2">
      <button type="button" data-system="all" aria-pressed="true" class="system-chip rounded-full border border-guards bg-guards/15 px-3 py-1 text-xs font-semibold text-guards transition">All systems</button>
      {MANUAL_CATEGORIES.map((c) => (
        <button type="button" data-system={c.id} aria-pressed="false" class="system-chip inline-flex items-center gap-1.5 rounded-full border border-line bg-surface px-3 py-1 text-xs font-semibold text-ink-soft transition hover:border-guards/40">
          <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d={c.icon} /></svg>
          {c.short}
        </button>
      ))}
    </div>
  </div>

  <div class="mt-5 flex items-center gap-2 rounded-lg border border-line bg-surface px-4 py-2.5 focus-within:border-guards/50">
    <svg viewBox="0 0 24 24" class="h-4.5 w-4.5 text-ink-soft/50" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" /></svg>
    <input id="part-search" type="search" placeholder="Search parts — e.g. belt, oil filter, clutch…" class="w-full bg-transparent text-sm text-ink outline-none placeholder:text-ink-soft/40" />
  </div>

  <p id="part-count" class="mt-5 font-mono text-xs uppercase tracking-wider text-ink-soft/50"></p>

  <!-- ── Results, grouped by kind ─────────────────────── -->
  {KINDS.map((kind) => {
    const parts = PARTS.filter((p) => p.kind === kind.id);
    if (parts.length === 0) return null;
    return (
      <section class="kind-group mt-6" data-kind={kind.id}>
        <h2 class="font-display text-sm font-bold uppercase tracking-[0.12em] text-guards">{kind.name}</h2>
        <p class="mt-0.5 text-sm text-ink-soft/70">{kind.blurb}</p>
        <div class="mt-3 space-y-3">
          {parts.map((part) => {
            const used = usedIn.get(part.id) ?? [];
            const search = [part.name, part.partNumber, part.note, getCategory(part.system)?.name].filter(Boolean).join(' ').toLowerCase();
            return (
              <div
                class="part-card rounded-xl border border-line bg-surface p-5"
                data-system={part.system}
                data-fitment={part.fitment.join(' ')}
                data-search={search}
              >
                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                  <div class="min-w-0">
                    <div class="flex flex-wrap items-center gap-2">
                      <h3 class="font-display text-lg font-bold text-ink">{part.name}</h3>
                      {part.partNumber && <span class="rounded-md border border-guards/40 bg-guards/10 px-2 py-0.5 font-mono text-xs font-semibold text-guards-light">{part.partNumber}</span>}
                    </div>
                    <div class="mt-1.5 flex flex-wrap items-center gap-1.5">
                      <svg class="h-3.5 w-3.5 text-ink-soft/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d={getCategory(part.system)?.icon} /></svg>
                      <span class="text-xs font-medium text-ink-soft/70">{getCategory(part.system)?.name}</span>
                      <span class="text-ink-soft/30">·</span>
                      {part.fitment.map((f) => (
                        <span class="rounded-full bg-paper px-2 py-0.5 text-[0.6rem] font-bold uppercase tracking-wide text-ink-soft/70">{fitmentLabel(f)}</span>
                      ))}
                    </div>
                    {part.note && <p class="mt-2 max-w-2xl text-sm text-ink-soft">{part.note}</p>}
                  </div>
                </div>

                <div class="mt-3 flex flex-wrap items-center gap-2">
                  <span class="font-mono text-[0.6rem] font-bold uppercase tracking-wider text-ink-soft/50">Buy</span>
                  {part.buy.map((b) => (
                    <a href={b.url} target="_blank" rel="noopener nofollow sponsored" class="inline-flex items-center gap-1 rounded-md border border-line bg-paper px-2.5 py-1 text-xs font-semibold text-ink-soft transition hover:border-guards/50 hover:text-guards-light">
                      {b.label}
                      <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7M9 7h8v8" /></svg>
                    </a>
                  ))}
                  {part.printable && (
                    <a href={part.printable.url} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md border border-emerald-400/30 bg-emerald-400/10 px-2.5 py-1 text-xs font-semibold text-emerald-400 transition hover:border-emerald-400/60">
                      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8 12 3 3 8m18 0-9 5-9-5m18 0v8l-9 5-9-5V8" /></svg>
                      3D print
                    </a>
                  )}
                </div>

                {used.length > 0 && (
                  <div class="mt-3 border-t border-line/70 pt-3">
                    <span class="font-mono text-[0.6rem] font-bold uppercase tracking-wider text-ink-soft/50">Used in</span>
                    <span class="ml-1 inline-flex flex-wrap gap-1.5 align-middle">
                      {used.map((a) => (
                        <a href={a.url} class="inline-block rounded-md bg-paper px-2 py-0.5 text-xs text-ink-soft transition hover:text-guards-light">{a.title}</a>
                      ))}
                    </span>
                  </div>
                )}
              </div>
            );
          })}
        </div>
      </section>
    );
  })}

  <p id="part-empty" class="mt-10 hidden text-center text-ink-soft">No parts match. Try a different car, system or search — or suggest one below.</p>

  <!-- ── Factory parts catalogs ───────────────────────── -->
  <section class="mt-14 rounded-2xl border border-line bg-carbon-grid p-6">
    <h2 class="font-display text-lg font-extrabold text-white">Factory parts catalogs</h2>
    <p class="mt-1 max-w-2xl text-sm text-white/55">
      The official Porsche "V-Pages" illustrated parts catalogs — every part number, by model year and
      VIN. The definitive source when you need an exact OEM number.
    </p>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      {CATALOGS.map((c) => (
        <a href={withBase(`/catalogs/${c.file}`)} target="_blank" rel="noopener" class="group flex items-center gap-3 rounded-lg border border-white/10 bg-white/[0.03] p-4 hover:border-guards/50">
          <svg class="h-6 w-6 shrink-0 text-guards" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M14 3v5h5M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><path d="M9 13h6M9 17h6" /></svg>
          <span>
            <span class="block text-sm font-bold text-white group-hover:text-guards-light">944 · {c.year}</span>
            <span class="block text-xs text-white/45">PDF catalog</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- ── Suggest a part ───────────────────────────────── -->
  <div class="mt-6 flex flex-col gap-4 rounded-2xl border border-line bg-surface p-6 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h2 class="font-display text-lg font-extrabold text-ink">Know a good source for a part?</h2>
      <p class="mt-1 max-w-xl text-sm text-ink-soft">Share a part number, a buy link, or a 3D-printable model and we'll add it to the catalog.</p>
    </div>
    <a href={`${SITE.github}/issues/new?title=${encodeURIComponent('Parts catalog: ')}&labels=parts`} target="_blank" rel="noopener" class="shrink-0 rounded-md bg-guards px-5 py-3 text-sm font-bold text-white hover:bg-guards-dark">Suggest a part →</a>
  </div>
</BaseLayout>

<script>
  const cards = [...document.querySelectorAll<HTMLElement>('.part-card')];
  const groups = [...document.querySelectorAll<HTMLElement>('.kind-group')];
  const search = document.getElementById('part-search') as HTMLInputElement | null;
  const count = document.getElementById('part-count');
  const empty = document.getElementById('part-empty');

  let model = 'all';
  let system = 'all';
  let term = '';

  function apply() {
    let shown = 0;
    for (const card of cards) {
      const fitment = (card.dataset.fitment ?? '').split(' ');
      const matchModel = model === 'all' || fitment.includes('all') || fitment.includes(model);
      const matchSystem = system === 'all' || card.dataset.system === system;
      const matchTerm = !term || (card.dataset.search ?? '').includes(term);
      const visible = matchModel && matchSystem && matchTerm;
      card.classList.toggle('hidden', !visible);
      if (visible) shown++;
    }
    // Hide a kind heading when none of its cards are visible.
    for (const g of groups) {
      const anyVisible = [...g.querySelectorAll<HTMLElement>('.part-card')].some((c) => !c.classList.contains('hidden'));
      g.classList.toggle('hidden', !anyVisible);
    }
    if (count) count.textContent = `${shown} ${shown === 1 ? 'part' : 'parts'}`;
    empty?.classList.toggle('hidden', shown > 0);
  }

  function wireChips(selector: string, attr: string, set: (v: string) => void) {
    const chips = [...document.querySelectorAll<HTMLButtonElement>(selector)];
    chips.forEach((btn) =>
      btn.addEventListener('click', () => {
        set(btn.dataset[attr]!);
        chips.forEach((b) => {
          b.classList.remove('border-guards', 'bg-guards/15', 'text-guards');
          b.classList.add('border-line', 'bg-surface', 'text-ink-soft');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('border-guards', 'bg-guards/15', 'text-guards');
        btn.classList.remove('border-line', 'bg-surface', 'text-ink-soft');
        btn.setAttribute('aria-pressed', 'true');
        apply();
      }),
    );
  }

  wireChips('.model-chip', 'model', (v) => (model = v));
  wireChips('.system-chip', 'system', (v) => (system = v));
  search?.addEventListener('input', () => {
    term = search.value.trim().toLowerCase();
    apply();
  });

  apply();
</script>
