---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PARTS } from '../data/parts';
import { getArticles } from '../lib/content';
import { withBase } from '../lib/url';
import { SITE } from '../lib/site';

// Reverse index: part id -> [{ title, url }] of articles that use it.
const articles = await getArticles();
const usedIn = new Map<string, { title: string; url: string }[]>();
for (const a of articles) {
  for (const id of a.data.parts ?? []) {
    if (!usedIn.has(id)) usedIn.set(id, []);
    usedIn.get(id)!.push({
      title: a.data.title,
      url: withBase(`/manual/${a.data.category}/${a.id.split('/').pop()}`),
    });
  }
}
for (const list of usedIn.values()) list.sort((x, y) => x.title.localeCompare(y.title));
---

<BaseLayout title="Parts & Consumables" description="Replacement parts and consumables for the Porsche 944, with where to buy and which guides use them.">
  <p class="text-sm font-bold uppercase tracking-wider text-guards">Reference</p>
  <h1 class="mt-1 font-display text-4xl font-extrabold uppercase tracking-tight text-ink">Parts &amp; Consumables</h1>
  <p class="mt-2 max-w-3xl text-ink-soft">
    Replacement parts and consumables referenced across the guides, with manufacturer part numbers and
    where to buy. Always verify fitment for your specific year and variant before ordering.
  </p>
  <p class="mt-3 max-w-3xl text-xs text-ink-soft/60">{SITE.affiliate.short}</p>

  <div class="mt-8 space-y-3">
    {PARTS.map((part) => {
      const used = usedIn.get(part.id) ?? [];
      return (
        <div id={part.id} class="scroll-mt-24 rounded-xl border border-line bg-surface p-5">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-2">
                <h2 class="font-display text-lg font-bold text-ink">{part.name}</h2>
                {part.partNumber && <span class="rounded-md border border-guards/40 bg-guards/10 px-2 py-0.5 font-mono text-xs font-semibold text-guards-light">{part.partNumber}</span>}
              </div>
              {part.note && <p class="mt-1 text-sm text-ink-soft">{part.note}</p>}
            </div>
            <div class="flex shrink-0 flex-wrap gap-2">
              {part.buy.map((b) => (
                <a href={b.url} target="_blank" rel="noopener nofollow sponsored" class="inline-flex items-center gap-1 rounded-md border border-line bg-paper px-2.5 py-1.5 text-xs font-semibold text-ink-soft transition hover:border-guards/50 hover:text-guards-light">
                  {b.label}
                  <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7M9 7h8v8" /></svg>
                </a>
              ))}
            </div>
          </div>
          {used.length > 0 && (
            <details class="group mt-3 border-t border-line/70 pt-3">
              <summary class="flex cursor-pointer list-none items-center gap-1.5 text-xs font-semibold text-ink-soft hover:text-ink">
                <svg class="h-3.5 w-3.5 transition group-open:rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6" /></svg>
                Used in {used.length} {used.length === 1 ? 'guide' : 'guides'}
              </summary>
              <ul class="mt-2 flex flex-wrap gap-1.5">
                {used.map((a) => (
                  <li><a href={a.url} class="inline-block rounded-md bg-paper px-2 py-1 text-xs text-ink-soft transition hover:text-guards-light">{a.title}</a></li>
                ))}
              </ul>
            </details>
          )}
        </div>
      );
    })}
  </div>
</BaseLayout>
