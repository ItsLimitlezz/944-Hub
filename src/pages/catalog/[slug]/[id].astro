---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { CATALOGS, getCatalog, normPN } from '../../../lib/catalog';
import { PARTS } from '../../../data/parts';
import { getTorqueSectionsForIllus } from '../../../lib/torque';
import { getFFP } from '../../../data/ffp-products';
import { withBase } from '../../../lib/url';

export const getStaticPaths = (() =>
  CATALOGS.flatMap((c) =>
    c.illustrations.map((i) => ({ params: { slug: c.slug, id: i.id }, props: { catalogSlug: c.slug } })),
  )) satisfies GetStaticPaths;

const { slug, id } = Astro.params;
const catalog = getCatalog(slug!)!;
const idx = catalog.illustrations.findIndex((i) => i.id === id);
const ill = catalog.illustrations[idx];
const group = catalog.illustrations.filter((i) => i.group === ill.group);
const gi = group.findIndex((i) => i.id === ill.id);
const prev = group[gi - 1];
const next = group[gi + 1];

// Cross-reference our curated parts (with verified buy links) by part number.
const curatedByPN = new Map(PARTS.filter((p) => p.partNumber).map((p) => [normPN(p.partNumber!), p]));
const ebay = (pn: string) => `https://www.ebay.com/sch/i.html?_nkw=${encodeURIComponent(pn)}`;
const google = (pn: string) => `https://www.google.com/search?q=${encodeURIComponent('porsche 944 ' + pn)}`;
const slugId = (i: { id: string }) => withBase(`/catalog/${catalog.slug}/${i.id}`);
const torqueSections = getTorqueSectionsForIllus(ill.id);
---

<BaseLayout title={`${ill.title} (${ill.id})`} description={`Porsche 944 ${ill.title} — exploded diagram and OEM part numbers (illustration ${ill.id}, ${catalog.label}).`}>
  <nav class="text-sm text-ink-soft/70">
    <a href={withBase('/parts')} class="hover:text-guards">Parts</a> <span class="px-1">/</span>
    <a href={withBase('/catalog')} class="hover:text-guards">Catalog</a> <span class="px-1">/</span>
    <span class="text-ink">{ill.groupName}</span>
  </nav>

  <div class="mt-3 flex flex-wrap items-end justify-between gap-3 border-b border-line pb-5">
    <div>
      <p class="font-mono text-xs font-bold uppercase tracking-wider text-guards">{ill.groupName} · {ill.id}</p>
      <h1 class="mt-1 font-display text-3xl font-extrabold text-ink sm:text-4xl">{ill.title}</h1>
      <p class="mt-1 text-sm text-ink-soft">{catalog.label} · {catalog.model} · {ill.parts.length} parts</p>
    </div>
    <div class="flex gap-2">
      {prev && <a href={slugId(prev)} class="rounded-md border border-line px-3 py-1.5 text-xs font-semibold text-ink-soft hover:border-guards/40" title={prev.title}>← {prev.id}</a>}
      {next && <a href={slugId(next)} class="rounded-md border border-line px-3 py-1.5 text-xs font-semibold text-ink-soft hover:border-guards/40" title={next.title}>{next.id} →</a>}
    </div>
  </div>

  {torqueSections.length > 0 && (
    <div class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-2 rounded-lg border border-guards/30 bg-guards/[0.06] p-4">
      <span class="inline-flex items-center gap-1.5 font-display text-sm font-bold uppercase tracking-wider text-ink">
        <svg class="h-4 w-4 text-guards" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a4 4 0 0 0-5.4 5.3L3 18l3 3 6.4-6.3a4 4 0 0 0 5.3-5.4l-2.6 2.6-2.3-.4-.4-2.3z" /></svg>
        Torque specs
      </span>
      <span class="text-sm text-ink-soft">Tightening values for these fasteners are in the Master List:</span>
      {torqueSections.map((s) => (
        <a href={withBase(s.url)} class="rounded-md border border-guards/40 bg-guards/10 px-2.5 py-1 text-xs font-semibold text-guards-light hover:border-guards">{s.heading} →</a>
      ))}
    </div>
  )}

  <div class="mt-6 lg:grid lg:grid-cols-[minmax(0,1fr)_minmax(0,1.1fr)] lg:gap-8">
    <!-- Diagram -->
    <div class="lg:sticky lg:top-20 lg:self-start">
      {ill.image ? (
        <a href={withBase(ill.image)} target="_blank" rel="noopener" class="group block overflow-hidden rounded-xl border border-line bg-white">
          <img src={withBase(ill.image)} alt={`${ill.title} exploded diagram`} class="w-full object-contain" />
        </a>
      ) : (
        <div class="grid aspect-[3/4] place-items-center rounded-xl border border-line bg-surface text-ink-soft/40">No diagram available</div>
      )}
      <p class="mt-2 text-center text-xs text-ink-soft/50">Numbers on the diagram match the <strong class="text-ink-soft">Pos</strong> column. Tap the image to enlarge.</p>
    </div>

    <!-- Parts table -->
    <div class="mt-6 lg:mt-0">
      <div class="overflow-hidden rounded-xl border border-line">
        <table class="w-full text-sm">
          <thead class="bg-surface text-left font-mono text-[0.6rem] uppercase tracking-wider text-ink-soft/60">
            <tr>
              <th class="px-3 py-2 font-bold">Pos</th>
              <th class="px-3 py-2 font-bold">Part number</th>
              <th class="px-3 py-2 font-bold">Description</th>
              <th class="px-3 py-2 text-right font-bold">Find</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-line/70">
            {ill.parts.map((p) => {
              const curated = curatedByPN.get(normPN(p.pn));
              const ffp = getFFP(p.pn);
              return (
                <tr class="align-top hover:bg-surface/60">
                  <td class="px-3 py-2 font-mono text-xs text-ink-soft/70">{p.pos || '—'}</td>
                  <td class="px-3 py-2">
                    <button class="copy-pn rounded font-mono text-xs font-semibold text-guards-light hover:underline" data-pn={p.pn} title="Copy part number">{p.pn}</button>
                  </td>
                  <td class="px-3 py-2 text-ink">
                    {p.desc}
                    {p.spec && <span class="ml-1.5 rounded bg-paper px-1.5 py-0.5 font-mono text-[0.62rem] font-semibold text-ink-soft/80">{p.spec}</span>}
                    {curated && (
                      <span class="mt-1 flex flex-wrap gap-1.5">
                        {curated.buy.map((b) => (
                          <a href={b.url} target="_blank" rel="noopener nofollow sponsored" class="inline-flex items-center gap-0.5 rounded border border-guards/40 bg-guards/10 px-1.5 py-0.5 text-[0.6rem] font-bold text-guards-light hover:border-guards">{b.label}</a>
                        ))}
                      </span>
                    )}
                  </td>
                  <td class="px-3 py-2 text-right whitespace-nowrap">
                    {ffp ? (
                      <a href={ffp.url} target="_blank" rel="noopener" class="inline-flex items-center rounded border border-guards/50 bg-guards/15 px-2 py-0.5 text-[0.62rem] font-bold uppercase tracking-wide text-guards-light transition hover:border-guards hover:bg-guards/25" title="Buy from FormFactor Performance">FFP</a>
                    ) : (
                      <>
                        <a href={ebay(p.pn)} target="_blank" rel="noopener nofollow" class="text-xs font-semibold text-ink-soft hover:text-guards-light">eBay</a>
                        <span class="px-1 text-ink-soft/30">·</span>
                        <a href={google(p.pn)} target="_blank" rel="noopener nofollow" class="text-xs font-semibold text-ink-soft hover:text-guards-light">Web</a>
                      </>
                    )}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs text-ink-soft/60">
        Part numbers are read directly from the factory catalog ({catalog.label}). Always confirm fitment for your VIN — supersessions happen.
        <a href={withBase('/parts')} class="font-semibold text-guards-light hover:underline">See curated parts with verified buy links →</a>
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-pn').forEach((btn) =>
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(btn.dataset.pn ?? '');
        const old = btn.textContent;
        btn.textContent = 'copied!';
        setTimeout(() => (btn.textContent = old), 1000);
      } catch {}
    }),
  );
</script>
