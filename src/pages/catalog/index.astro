---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CATALOGS, MAIN_GROUPS, allIllustrations, normPN } from '../../lib/catalog';
import { withBase } from '../../lib/url';

const illus = allIllustrations();
// Only show groups that actually have illustrations.
const present = new Set(illus.map((i) => i.group));
const groups = MAIN_GROUPS.filter((g) => present.has(g.id));
const slugId = (catalogSlug: string, id: string) => withBase(`/catalog/${catalogSlug}/${id}`);
---

<BaseLayout title="Visual Parts Catalog" description="Browse the Porsche 944 factory parts catalog visually — exploded diagrams for every assembly, with accurate OEM part numbers.">
  <p class="text-sm font-bold uppercase tracking-wider text-guards">Reference</p>
  <h1 class="mt-1 font-display text-4xl font-extrabold uppercase tracking-tight text-ink">Visual Parts Catalog</h1>
  <p class="mt-2 max-w-3xl text-ink-soft">
    The official Porsche factory catalog, made browsable. Find the assembly, see the exploded diagram,
    and read off the exact OEM part number. Search by part name or number across every diagram.
  </p>

  <!-- Catalog (year) selector -->
  {CATALOGS.length > 1 && (
    <div class="mt-6">
      <p class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.18em] text-ink-soft/50">Catalog</p>
      <div id="catalog-filter" class="mt-2 flex flex-wrap gap-2">
        {CATALOGS.map((c, idx) => (
          <button type="button" data-catalog={c.slug} aria-pressed={idx === 0 ? 'true' : 'false'} class={`cat-chip rounded-full border px-3 py-1.5 text-sm font-semibold transition ${idx === 0 ? 'border-guards bg-guards/15 text-guards' : 'border-line bg-surface text-ink-soft hover:border-guards/40'}`}>
            {c.label} · {c.model}
          </button>
        ))}
      </div>
    </div>
  )}

  <!-- Group filter -->
  <div class="mt-5">
    <p class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.18em] text-ink-soft/50">System</p>
    <div id="group-filter" class="mt-2 flex flex-wrap gap-2">
      <button type="button" data-group="all" aria-pressed="true" class="group-chip rounded-full border border-guards bg-guards/15 px-3 py-1 text-xs font-semibold text-guards transition">All</button>
      {groups.map((g) => (
        <button type="button" data-group={g.id} aria-pressed="false" class="group-chip inline-flex items-center gap-1.5 rounded-full border border-line bg-surface px-3 py-1 text-xs font-semibold text-ink-soft transition hover:border-guards/40">
          <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d={g.icon} /></svg>
          {g.name}
        </button>
      ))}
    </div>
  </div>

  <div class="mt-5 flex items-center gap-2 rounded-lg border border-line bg-surface px-4 py-2.5 focus-within:border-guards/50">
    <svg viewBox="0 0 24 24" class="h-4.5 w-4.5 text-ink-soft/50" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" /></svg>
    <input id="catalog-search" type="search" placeholder="Search diagrams & parts — e.g. head gasket, water pump, 944 104…" class="w-full bg-transparent text-sm text-ink outline-none placeholder:text-ink-soft/40" />
  </div>

  <p id="catalog-count" class="mt-5 font-mono text-xs uppercase tracking-wider text-ink-soft/50"></p>

  <div id="illus-grid" class="mt-3 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
    {illus.map((i) => {
      const search = [i.id, i.title, i.groupName, ...i.parts.map((p) => p.desc), ...i.parts.map((p) => normPN(p.pn))].join(' ').toLowerCase();
      return (
        <a
          href={slugId(i.catalogSlug, i.id)}
          class="illus-card group flex flex-col overflow-hidden rounded-xl border border-line bg-surface transition hover:-translate-y-0.5 hover:border-guards/50"
          data-catalog={i.catalogSlug}
          data-group={i.group}
          data-search={search}
        >
          <div class="aspect-[4/3] overflow-hidden border-b border-line bg-white">
            {i.image ? (
              <img src={withBase(i.image)} alt={`${i.title} diagram`} loading="lazy" class="h-full w-full object-contain p-1 transition group-hover:scale-[1.03]" />
            ) : (
              <div class="grid h-full place-items-center text-xs text-ink-soft/40">No diagram</div>
            )}
          </div>
          <div class="flex flex-1 flex-col p-3">
            <div class="flex items-center gap-1.5">
              <span class="font-mono text-[0.6rem] font-bold text-guards-light">{i.id}</span>
              <span class="font-mono text-[0.55rem] uppercase tracking-wide text-ink-soft/45">{i.groupName}</span>
            </div>
            <h3 class="mt-0.5 font-semibold leading-tight text-ink group-hover:text-guards-light">{i.title}</h3>
            <span class="mt-auto pt-1.5 text-xs text-ink-soft/60">{i.parts.length} {i.parts.length === 1 ? 'part' : 'parts'}</span>
          </div>
        </a>
      );
    })}
  </div>
  <p id="catalog-empty" class="mt-10 hidden text-center text-ink-soft">No diagrams match. Try another system or search term.</p>
</BaseLayout>

<script>
  const cards = [...document.querySelectorAll<HTMLElement>('.illus-card')];
  const search = document.getElementById('catalog-search') as HTMLInputElement | null;
  const count = document.getElementById('catalog-count');
  const empty = document.getElementById('catalog-empty');

  const firstCat = document.querySelector<HTMLElement>('.cat-chip')?.dataset.catalog ?? cards[0]?.dataset.catalog ?? '';
  let catalog = firstCat;
  let group = 'all';
  let term = '';

  function apply() {
    let shown = 0;
    for (const card of cards) {
      const matchCat = !catalog || card.dataset.catalog === catalog;
      const matchGroup = group === 'all' || card.dataset.group === group;
      const matchTerm = !term || (card.dataset.search ?? '').includes(term);
      const visible = matchCat && matchGroup && matchTerm;
      card.classList.toggle('hidden', !visible);
      if (visible) shown++;
    }
    if (count) count.textContent = `${shown} ${shown === 1 ? 'diagram' : 'diagrams'}`;
    empty?.classList.toggle('hidden', shown > 0);
  }

  function wire(selector: string, attr: string, set: (v: string) => void) {
    const chips = [...document.querySelectorAll<HTMLButtonElement>(selector)];
    chips.forEach((btn) =>
      btn.addEventListener('click', () => {
        set(btn.dataset[attr]!);
        chips.forEach((b) => {
          b.classList.remove('border-guards', 'bg-guards/15', 'text-guards');
          b.classList.add('border-line', 'bg-surface', 'text-ink-soft');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('border-guards', 'bg-guards/15', 'text-guards');
        btn.classList.remove('border-line', 'bg-surface', 'text-ink-soft');
        btn.setAttribute('aria-pressed', 'true');
        apply();
      }),
    );
  }

  wire('.cat-chip', 'catalog', (v) => (catalog = v));
  wire('.group-chip', 'group', (v) => (group = v));
  search?.addEventListener('input', () => {
    term = search.value.trim().toLowerCase();
    apply();
  });
  apply();
</script>
