---
import ArticleCard from './ArticleCard.astro';
import { MANUAL_CATEGORIES, EXTRA_CATEGORIES } from '../lib/categories';
import type { Article } from '../lib/content';
import { withBase } from '../lib/url';

interface Props {
  title: string;
  intro?: string;
  /** 'all' for the shop-manual home, otherwise the active category id. */
  active: string;
  articles: Article[];
}
const { title, intro, active, articles } = Astro.props;
const slugOf = (id: string) => id.split('/').pop();

const navItem = (href: string, isActive: boolean) =>
  [
    'group flex items-center gap-2.5 rounded-md px-3 py-2 text-sm font-medium transition',
    isActive
      ? 'bg-guards/12 text-guards'
      : 'text-ink-soft hover:bg-surface-2 hover:text-ink',
  ].join(' ');
---

<div class="lg:grid lg:grid-cols-[15rem_1fr] lg:gap-8">
  <!-- ── Category sidebar ─────────────────────────────── -->
  <aside class="mb-8 lg:mb-0">
    <div class="sticky top-20">
      <p class="px-3 pb-2 font-mono text-[0.65rem] font-bold uppercase tracking-[0.18em] text-ink-soft/50">Categories</p>
      <nav class="space-y-0.5">
        <a href={withBase('/manual')} class={navItem('/manual', active === 'all')}>
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16M4 12h16M4 18h16" /></svg>
          All Articles
        </a>
        {MANUAL_CATEGORIES.map((c) => (
          <a href={withBase(`/manual/${c.id}`)} class={navItem(`/manual/${c.id}`, active === c.id)}>
            <svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d={c.icon} /></svg>
            {c.name}
          </a>
        ))}
      </nav>

      <p class="mt-6 px-3 pb-2 font-mono text-[0.65rem] font-bold uppercase tracking-[0.18em] text-ink-soft/50">Reference</p>
      <nav class="space-y-0.5">
        {EXTRA_CATEGORIES.map((c) => (
          <a href={withBase(`/manual/${c.id}`)} class={navItem(`/manual/${c.id}`, active === c.id)}>
            <svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d={c.icon} /></svg>
            {c.name}
          </a>
        ))}
      </nav>
    </div>
  </aside>

  <!-- ── Main column ──────────────────────────────────── -->
  <section class="min-w-0">
    <h1 class="font-display text-3xl font-extrabold uppercase tracking-tight text-ink sm:text-4xl">{title}</h1>
    {intro && <p class="mt-2 max-w-2xl text-ink-soft">{intro}</p>}

    <div class="mt-6 flex items-center gap-2 rounded-lg border border-line bg-surface px-4 py-2.5 focus-within:border-guards/50">
      <svg viewBox="0 0 24 24" class="h-4.5 w-4.5 text-ink-soft/50" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" /></svg>
      <input id="manual-search" type="search" placeholder="Search articles…" class="w-full bg-transparent text-sm text-ink outline-none placeholder:text-ink-soft/40" />
    </div>

    <p id="manual-count" class="mt-5 font-mono text-xs uppercase tracking-wider text-ink-soft/50">{articles.length} articles</p>

    <div id="manual-list" class="mt-3 space-y-3">
      {articles.map((a) => (
        <ArticleCard
          href={withBase(`/manual/${a.data.category}/${slugOf(a.id)}`)}
          title={a.data.title}
          author={a.data.author}
          authorName={a.data.authorName}
          difficulty={a.data.difficulty}
          code={a.data.code}
          subsystem={a.data.subsystem}
          description={a.data.description}
        />
      ))}
    </div>
    <p id="manual-empty" class="mt-10 hidden text-center text-ink-soft">No matching articles. Try another term.</p>
  </section>
</div>

<script>
  const input = document.getElementById('manual-search') as HTMLInputElement | null;
  const cards = [...document.querySelectorAll<HTMLElement>('#manual-list .article-card')];
  const count = document.getElementById('manual-count');
  const empty = document.getElementById('manual-empty');

  input?.addEventListener('input', () => {
    const term = input.value.trim().toLowerCase();
    let shown = 0;
    for (const card of cards) {
      const match = !term || (card.dataset.search ?? '').includes(term);
      card.classList.toggle('hidden', !match);
      if (match) shown++;
    }
    if (count) count.textContent = `${shown} ${shown === 1 ? 'article' : 'articles'}`;
    empty?.classList.toggle('hidden', shown > 0);
  });
</script>
