---
import AttributionBadge from './AttributionBadge.astro';
import type { AuthorKey } from '../lib/site';

interface Props {
  href: string;
  title: string;
  author: AuthorKey;
  authorName?: string;
  code?: string;
  description?: string;
}
const { href, title, author, authorName, code, description } = Astro.props;
---

<a href={href} class="group flex items-start gap-3 rounded-lg border border-transparent px-3 py-2.5 transition hover:border-line hover:bg-surface">
  <svg class="mt-1 h-4 w-4 shrink-0 text-line transition group-hover:text-guards" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6" /></svg>
  <span class="min-w-0 flex-1">
    <span class="flex flex-wrap items-center gap-2">
      <span class="font-medium text-ink group-hover:text-guards-dark">{title}</span>
      <AttributionBadge author={author} authorName={authorName} />
      {code && <span class="font-mono text-[0.6rem] uppercase tracking-wide text-ink-soft/50">{code}</span>}
    </span>
    {description && <span class="mt-0.5 block truncate text-sm text-ink-soft/70">{description}</span>}
  </span>
</a>
