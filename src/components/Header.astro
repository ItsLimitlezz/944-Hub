---
import Logo from './Logo.astro';
import { MANUAL_CATEGORIES, EXTRA_CATEGORIES } from '../lib/categories';
import { SITE } from '../lib/site';
import { withBase } from '../lib/url';

const basePrefix = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = Astro.url.pathname.replace(basePrefix, '') || '/';
const isActive = (href: string) => path === href || path.startsWith(href + '/');

// Auto-expand the mobile "Shop Manual" section when browsing the manual.
const manualOpen = isActive('/manual');

// Simple line icons for the mobile menu (24x24 stroke paths).
const NAV_ICONS = {
  book: 'M4 19.5A2.5 2.5 0 0 1 6.5 17H20M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z',
  all: 'M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01',
  tools: 'M14.7 6.3a4 4 0 0 0-5.4 5.3L3 18l3 3 6.4-6.3a4 4 0 0 0 5.3-5.4l-2.6 2.6-2.3-.4-.4-2.3z',
  parts: 'M21 8 12 3 3 8m18 0-9 5-9-5m18 0v8l-9 5-9-5V8',
  catalog: 'M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z',
  community: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm13 10v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
  shops: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10ZM9 12l2 2 4-4',
  about: 'M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20ZM12 16v-4M12 8h.01',
};

// Top-level destinations beyond the Shop Manual, in mobile-menu order.
const PRIMARY_LINKS = [
  { href: '/tools', label: 'Tools', icon: NAV_ICONS.tools },
  { href: '/parts', label: 'Parts', icon: NAV_ICONS.parts },
  { href: '/catalog', label: 'Visual Catalog', icon: NAV_ICONS.catalog },
  { href: '/community', label: 'Community', icon: NAV_ICONS.community },
  { href: '/shops', label: 'Trusted Shops', icon: NAV_ICONS.shops },
  { href: '/about', label: 'About', icon: NAV_ICONS.about },
];
---

<header class="sticky top-0 z-50 bg-carbon/95 backdrop-blur supports-[backdrop-filter]:bg-carbon/80 border-b border-white/10">
  <div class="mx-auto flex h-16 max-w-7xl items-center gap-4 px-4 sm:px-6 lg:px-8">
    <Logo />

    <nav class="ml-4 hidden items-center gap-1 lg:flex" aria-label="Primary">
      <!-- Shop Manual dropdown -->
      <div class="group relative">
        <a
          href={withBase('/manual')}
          class:list={[
            'flex items-center gap-1 rounded-md px-3 py-2 text-sm font-semibold hover:bg-white/10 hover:text-white',
            isActive('/manual') ? 'text-white' : 'text-white/80',
          ]}
        >
          Shop Manual
          <svg class="h-3.5 w-3.5 text-white/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6" /></svg>
        </a>
        <div class="invisible absolute left-0 top-full w-72 translate-y-1 pt-2 opacity-0 transition group-hover:visible group-hover:translate-y-0 group-hover:opacity-100">
          <div class="overflow-hidden rounded-xl border border-line bg-surface p-2 shadow-xl">
            {MANUAL_CATEGORIES.map((c) => (
              <a href={withBase(`/manual/${c.id}`)} class="flex items-start gap-3 rounded-lg p-2.5 hover:bg-paper">
                <span class="mt-0.5 grid h-8 w-8 shrink-0 place-items-center rounded-md bg-guards/10 text-guards">
                  <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d={c.icon} /></svg>
                </span>
                <span>
                  <span class="block text-sm font-semibold text-ink">{c.name}</span>
                  <span class="block text-xs text-ink-soft/80">{c.blurb}</span>
                </span>
              </a>
            ))}
            <div class="my-1.5 border-t border-line"></div>
            <div class="flex flex-wrap gap-1 px-1.5 pb-1">
              {EXTRA_CATEGORIES.map((c) => (
                <a href={withBase(`/manual/${c.id}`)} class="rounded-md px-2 py-1 text-xs font-semibold text-ink-soft hover:bg-paper hover:text-guards-dark">{c.name}</a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <a
        href={withBase('/tools')}
        class:list={['rounded-md px-3 py-2 text-sm font-semibold hover:bg-white/10 hover:text-white', isActive('/tools') ? 'text-white' : 'text-white/80']}
      >
        Tools
      </a>
      <a
        href={withBase('/parts')}
        class:list={['rounded-md px-3 py-2 text-sm font-semibold hover:bg-white/10 hover:text-white', isActive('/parts') ? 'text-white' : 'text-white/80']}
      >
        Parts
      </a>
      <a
        href={withBase('/catalog')}
        class:list={['rounded-md px-3 py-2 text-sm font-semibold hover:bg-white/10 hover:text-white', isActive('/catalog') ? 'text-white' : 'text-white/80']}
      >
        Catalog
      </a>
      <a
        href={withBase('/community')}
        class:list={['rounded-md px-3 py-2 text-sm font-semibold hover:bg-white/10 hover:text-white', isActive('/community') ? 'text-white' : 'text-white/80']}
      >
        Community
      </a>
      <a
        href={withBase('/shops')}
        class:list={['rounded-md px-3 py-2 text-sm font-semibold hover:bg-white/10 hover:text-white', isActive('/shops') ? 'text-white' : 'text-white/80']}
      >
        Trusted Shops
      </a>
      <a
        href={withBase('/about')}
        class:list={['rounded-md px-3 py-2 text-sm font-semibold hover:bg-white/10 hover:text-white', isActive('/about') ? 'text-white' : 'text-white/80']}
      >
        About
      </a>
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <a href={withBase('/search')} class="grid h-9 w-9 place-items-center rounded-md text-white/70 hover:bg-white/10 hover:text-white" aria-label="Search">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" /></svg>
      </a>
      <a href={SITE.github} target="_blank" rel="noopener" class="hidden h-9 w-9 place-items-center rounded-md text-white/70 hover:bg-white/10 hover:text-white sm:grid" aria-label="GitHub repository">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true"><path d="M12 2A10 10 0 0 0 8.8 21.5c.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.3-3.4-1.3-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.5 2.3 1.1 2.9.8.1-.7.3-1.1.6-1.4-2.2-.300-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.7 1a9.4 9.4 0 0 1 5 0c1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.9-2.4 4.7-4.6 5 .3.3.6.9.6 1.8v2.7c0 .3.2.6.7.5A10 10 0 0 0 12 2Z" /></svg>
      </a>
      <a
        href={withBase('/contribute')}
        class="hidden rounded-md bg-guards px-3.5 py-2 text-sm font-bold text-white shadow-sm hover:bg-guards-dark sm:inline-block"
      >
        Contribute
      </a>
      <!-- Mobile menu toggle -->
      <button id="mobile-toggle" class="grid h-9 w-9 place-items-center rounded-md text-white/80 hover:bg-white/10 lg:hidden" aria-label="Menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16" /></svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden max-h-[calc(100dvh-4rem)] overflow-y-auto border-t border-white/10 bg-carbon lg:hidden">
    <nav class="mx-auto max-w-7xl px-3 py-3" aria-label="Mobile">
      <!-- Shop Manual — collapsible -->
      <button
        id="m-manual-toggle"
        class:list={[
          'flex w-full items-center justify-between rounded-lg px-3 py-3 text-[0.95rem] font-bold hover:bg-white/5',
          isActive('/manual') ? 'text-white' : 'text-white/90',
        ]}
        aria-expanded={manualOpen ? 'true' : 'false'}
        aria-controls="m-manual-panel"
      >
        <span class="flex items-center gap-3">
          <svg viewBox="0 0 24 24" class="h-5 w-5 text-guards" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d={NAV_ICONS.book} /></svg>
          Shop Manual
        </span>
        <svg id="m-manual-chevron" viewBox="0 0 24 24" class:list={['h-4 w-4 text-white/50 transition-transform', manualOpen && 'rotate-180']} fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6" /></svg>
      </button>

      <div id="m-manual-panel" class:list={['ml-4 mt-0.5 space-y-0.5 border-l border-white/10 pl-3', !manualOpen && 'hidden']}>
        <a href={withBase('/manual')} class:list={['flex items-center gap-3 rounded-md px-3 py-2 text-sm font-semibold hover:bg-white/5', path === '/manual' ? 'text-guards' : 'text-white/85']}>
          <svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0 text-white/45" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d={NAV_ICONS.all} /></svg>
          All articles
        </a>
        {MANUAL_CATEGORIES.map((c) => (
          <a href={withBase(`/manual/${c.id}`)} class:list={['flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium hover:bg-white/5', isActive(`/manual/${c.id}`) ? 'text-guards' : 'text-white/75']}>
            <svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0 text-white/45" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d={c.icon} /></svg>
            {c.name}
          </a>
        ))}
        <div class="my-1 border-t border-white/5"></div>
        {EXTRA_CATEGORIES.map((c) => (
          <a href={withBase(`/manual/${c.id}`)} class:list={['flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium hover:bg-white/5', isActive(`/manual/${c.id}`) ? 'text-guards' : 'text-white/75']}>
            <svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0 text-white/45" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d={c.icon} /></svg>
            {c.name}
          </a>
        ))}
      </div>

      <div class="my-2 border-t border-white/10"></div>

      {PRIMARY_LINKS.map((item) => (
        <a
          href={withBase(item.href)}
          class:list={[
            'flex items-center gap-3 rounded-lg px-3 py-3 text-[0.95rem] font-semibold',
            isActive(item.href) ? 'bg-white/10 text-white' : 'text-white/80 hover:bg-white/5 hover:text-white',
          ]}
        >
          <svg viewBox="0 0 24 24" class="h-5 w-5 shrink-0 text-white/50" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d={item.icon} /></svg>
          {item.label}
        </a>
      ))}

      <a href={withBase('/contribute')} class="mt-3 block rounded-lg bg-guards px-3 py-3 text-center text-[0.95rem] font-bold text-white hover:bg-guards-dark">Contribute</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });

  // Collapsible "Shop Manual" section inside the mobile menu.
  const mt = document.getElementById('m-manual-toggle');
  const mp = document.getElementById('m-manual-panel');
  const mc = document.getElementById('m-manual-chevron');
  mt?.addEventListener('click', () => {
    const open = mp?.classList.toggle('hidden') === false;
    mt.setAttribute('aria-expanded', String(open));
    mc?.classList.toggle('rotate-180', open);
  });
</script>
